# Copy this file to .env and fill in the values
# On Railway, set these as environment variables in the dashboard — do NOT commit .env

# The public URL Railway gives you e.g. https://yourapp.up.railway.app
# Used to embed the correct URL inside the QR code
BASE_URL=https://1timeqr.up.railway.app

# Name that appears on the scan page
WEDDING_NAME=Aisha &Francis Wedding

# Display date shown in the footer (e.g. "April 25, 2026")
WEDDING_DATE=

# ISO datetime when the admit button unlocks e.g. 2026-04-25T12:00:00Z
# Leave empty to always allow admissions
EVENT_DATE=

# Port — Railway sets this automatically, leave as 3000
PORT=3000

# Max guests allowed before entry is denied
CAPACITY=300

# CORS origin — set to your BASE_URL in production
CORS_ORIGIN=*

# --- MongoDB (not needed while using filesystem storage) ---
# MONGODB_URI=mongodb://localhost:27017/wedding_qr


# Server port (default: 3000)
PORT=3000

# CORS allowed origin (* = all, or set your frontend domain)
CORS_ORIGIN=*
